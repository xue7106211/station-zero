{
  "name": "station-zero",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --use-env-proxy ./node_modules/next/dist/bin/next dev",
    "build": "node --use-env-proxy ./node_modules/next/dist/bin/next build",
    "start": "node --use-env-proxy ./node_modules/next/dist/bin/next start",
    "lint": "eslint",
    "check:tmdb": "node --env-file=.env.local --use-env-proxy scripts/check-tmdb.mjs",
    "test": "node --test tests/*.test.mjs",
    "sync:movies": "node --env-file=.env.local --use-env-proxy scripts/sync-movies.mjs",
    "import:movies": "node scripts/import-movies.mjs"
  },
  "dependencies": {
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
