# TMDB 后台同步（可选）
TMDB_READ_ACCESS_TOKEN=
TMDB_API_KEY=

# Supabase Postgres（页面优先读 SQL）
# Transaction pooler URI，端口 6543
DATABASE_URL=

# Supabase Storage 上传（bulk-ingest sync / ingest:upload-media 专用，勿暴露给浏览器）
# Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# 可选；未设置时从 DATABASE_URL 推导 project ref
SUPABASE_URL=

# 可选；默认 media（与原先 16 部海报 bucket 一致）
SUPABASE_MEDIA_BUCKET=media

# 本地开发代理（可选）
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
