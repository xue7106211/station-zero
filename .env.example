# TMDB 后台同步（可选）
TMDB_READ_ACCESS_TOKEN=
TMDB_API_KEY=

# Supabase Postgres（页面优先读 SQL）
# Transaction pooler URI，端口 6543
DATABASE_URL=

# Supabase Storage 上传（bulk-ingest sync / ingest:upload-media 专用，勿暴露给浏览器）
# Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# 可选；未设置时从 DATABASE_URL 推导 project ref
SUPABASE_URL=

# 可选；默认 media（与原先 16 部海报 bucket 一致）
SUPABASE_MEDIA_BUCKET=media

# TMDB 海报源尺寸（bulk-ingest；默认 w500，见 docs/technical/poster-compression-scheme.md）
# TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500
# TMDB 背景图源尺寸（默认 w1280，与海报分离）
# TMDB_BACKDROP_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w1280
# 入库压缩（sharp；仅 bulk-ingest）
# POSTER_MAX_WIDTH=480
# POSTER_WEBP_QUALITY=78
# BACKDROP_MAX_WIDTH=1280
# BACKDROP_WEBP_QUALITY=72

# TMDB API 代理（可选；值需包含 /3 前缀）
# TMDB_API_BASE_URL=

# Next.js 图片优化（开发期 fake-ip DNS 排障时可设为 true）
# NEXT_IMAGE_UNOPTIMIZED=true

# 本地开发代理（可选）
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
